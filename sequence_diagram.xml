<mxfile host="app.diagrams.net">
  <diagram name="Sequence Diagram">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Lifelines -->
        <mxCell id="user" value="User" style="shape=umlLifeline;" vertex="1" parent="1">
          <mxGeometry x="100" y="50" width="100" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="frontend" value="Frontend" style="shape=umlLifeline;" vertex="1" parent="1">
          <mxGeometry x="300" y="50" width="100" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="backend" value="Backend" style="shape=umlLifeline;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="100" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="db" value="Database" style="shape=umlLifeline;" vertex="1" parent="1">
          <mxGeometry x="700" y="50" width="100" height="500" as="geometry"/>
        </mxCell>

        <!-- Messages -->
        <mxCell edge="1" parent="1" source="user" target="frontend" value="Enter Sale Details">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="frontend" target="backend" value="POST /create-sale">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="backend" target="db" value="Save Sale">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="db" target="backend" value="Success">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="backend" target="frontend" value="Response OK">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell edge="1" parent="1" source="frontend" target="user" value="Show Confirmation">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>