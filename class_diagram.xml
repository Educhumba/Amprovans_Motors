        <mxCell id="sale" value="Sale&#xa;----------------&#xa;sale_id&#xa;car_id&#xa;user_id&#xa;sold_price&#xa;commission&#xa;profit&#xa;date" style="rounded=0;" vertex="1" parent="1">
